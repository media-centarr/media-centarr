#!/usr/bin/env bash
# Regenerate the bundled showcase episode-thumbnail placeholders.
#
# The showcase catalog picks legally-safe public-domain / CC-licensed TV
# (Pioneer One, Dragnet 1951) that TMDB has NO episode stills for — every
# `still_path` comes back null. Without thumbs, the TV detail modal
# renders empty boxes, which is not marketing-grade.
#
# The seeder (`MediaCentarr.Showcase.seed_episode!`) falls back to one of
# these bundled gradients when TMDB has no still. Re-running this script
# is the only way to change their look; the output is committed so every
# checkout has consistent thumbs.
#
# Requires: ImageMagick 7 (`magick`).
#
# Output: priv/showcase/fixtures/thumbs/thumb-{1..5}.jpg

set -euo pipefail

OUT_DIR="$(cd "$(dirname "$0")/.." && pwd)/priv/showcase/fixtures/thumbs"
mkdir -p "$OUT_DIR"

# 16:9 at 400px wide — matches TMDB thumb resolution closely enough that
# the detail panel renders these at native pixel density.
SIZE="400x225"

# Five muted dark gradients. Distinct enough to tell episodes apart at
# a glance, uniformly dark so the UI's light-on-dark typography stays
# legible on hover state. Keep order stable — `seed_episode!` picks by
# episode_number modulo count.
gradients=(
  "#2e3a52-#0e1420"   # slate blue
  "#4a2e52-#140e1e"   # deep plum
  "#524a2e-#1e180e"   # amber/bronze
  "#2e5245-#0e1e1a"   # teal
  "#522e3d-#1e0e18"   # dusk rose
)

for i in "${!gradients[@]}"; do
  n=$((i + 1))
  magick -size "$SIZE" "gradient:${gradients[$i]}" "$OUT_DIR/thumb-${n}.jpg"
done

echo "generated ${#gradients[@]} thumbs at $OUT_DIR"
ls -la "$OUT_DIR"
