#!/usr/bin/env bash
# Regenerate the bundled showcase episode-thumbnail placeholders.
#
# These are the fallback thumbs used by the seeder
# (MediaCentarr.Showcase.bundle_episode_thumb!/1) for TV series where
# TMDB has no still_path — currently only Pioneer One (CC-BY-NC-SA).
#
# The design goal is "tasteful dark placeholder that reads as
# intentional, not as a broken thumbnail." We produce five fixtures so
# consecutive episodes get visual variety via
# rem(episode_number - 1, 5) + 1.
#
# Requires: ImageMagick 7 (`magick`).
#
# Output: priv/showcase/fixtures/thumbs/thumb-{1..5}.jpg

set -euo pipefail

OUT_DIR="$(cd "$(dirname "$0")/.." && pwd)/priv/showcase/fixtures/thumbs"
mkdir -p "$OUT_DIR"

# 400×225 matches TMDB's minimum episodic-backdrop spec so the detail
# panel renders natively without upscaling.
WIDTH=400
HEIGHT=225
SIZE="${WIDTH}x${HEIGHT}"

# Dark palette pulled from the app's ink scale. Not gradients — flat
# near-black with a subtle radial vignette.
BASE="#0f1117"
VIGNETTE="#1a1d26"

# Low-opacity ink for the glyphs — keeps the shot reading as "polite
# placeholder" rather than "look at me".
INK="rgba(255,255,255,0.11)"

# Center coordinates.
CX=$((WIDTH / 2))
CY=$((HEIGHT / 2))

# Five vector shapes drawn with ImageMagick primitives. Native drawing
# avoids the font-fallback trap we hit with unicode glyphs (▶ wasn't
# in the default font and silently rendered blank).
for n in 1 2 3 4 5; do
  case $n in
    1)
      # Equilateral play triangle pointing right, ~32px wide.
      draw="polygon $((CX - 14)),$((CY - 18)) $((CX - 14)),$((CY + 18)) $((CX + 18)),${CY}"
      ;;
    2)
      # Filled circle, radius 18.
      draw="circle ${CX},${CY} ${CX},$((CY - 18))"
      ;;
    3)
      # Square, ~32px wide.
      draw="rectangle $((CX - 16)),$((CY - 16)) $((CX + 16)),$((CY + 16))"
      ;;
    4)
      # Diamond (rotated square), ~44px diagonal.
      draw="polygon ${CX},$((CY - 22)) $((CX + 22)),${CY} ${CX},$((CY + 22)) $((CX - 22)),${CY}"
      ;;
    5)
      # Triangle pointing up, ~44px wide base.
      draw="polygon ${CX},$((CY - 20)) $((CX + 22)),$((CY + 18)) $((CX - 22)),$((CY + 18))"
      ;;
  esac

  magick -size "$SIZE" \
    radial-gradient:"$VIGNETTE"-"$BASE" \
    -fill "$INK" \
    -stroke none \
    -draw "$draw" \
    -quality 90 \
    "$OUT_DIR/thumb-${n}.jpg"
done

echo "generated 5 thumbs at $OUT_DIR"
ls -la "$OUT_DIR"
