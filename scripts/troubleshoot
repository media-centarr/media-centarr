#!/usr/bin/env bash
set -euo pipefail

# Troubleshoot a running Media Centarr production instance.
# All Elixir-side logic lives in MediaCentarr.Diagnostics — this script
# is a thin dispatcher that calls named functions, never inline code.
# Usage: scripts/troubleshoot [command] [args...]

service="media-centarr"
install_dir="$HOME/.local/lib/media-centarr"
bin="$install_dir/current/bin/media_centarr"
port=2160

bold="\033[1m"
dim="\033[2m"
red="\033[31m"
green="\033[32m"
yellow="\033[33m"
reset="\033[0m"

banner() { printf "\n${bold}── %s${reset}\n" "$1"; }
ok()     { printf "  ${green}✓${reset} %s\n" "$1"; }
warn()   { printf "  ${yellow}!${reset} %s\n" "$1"; }
fail()   { printf "  ${red}✗${reset} %s\n" "$1"; }
info()   { printf "  ${dim}%s${reset}\n" "$1"; }

# --- Helpers ---

require_release() {
  if [ ! -x "$bin" ]; then
    echo "Error: Release not found at $bin"
    echo "Install one: curl -fsSL https://raw.githubusercontent.com/media-centarr/media-centarr/main/installer/install.sh | sh"
    echo "(Or tag a new release with /ship <level> and update from Settings > Overview.)"
    exit 1
  fi
}

require_running() {
  if ! systemctl --user is-active --quiet "$service" 2>/dev/null; then
    echo "Error: Service $service is not running."
    echo "Start with: systemctl --user start $service"
    exit 1
  fi
}

diag() {
  "$bin" rpc "MediaCentarr.Diagnostics.$1"
}

# --- Commands ---

cmd_status() {
  banner "Service"
  if systemctl --user is-active --quiet "$service" 2>/dev/null; then
    ok "Running"
    pid=$("$bin" pid 2>/dev/null || echo "unknown")
    info "PID: $pid"
    info "Version: $("$bin" version 2>/dev/null || echo "unknown")"

    started=$(systemctl --user show "$service" --property=ActiveEnterTimestamp --value 2>/dev/null || true)
    if [ -n "$started" ]; then
      info "Started: $started"
    fi
  else
    fail "Not running"
    info "Start with: systemctl --user start $service"
  fi

  banner "Port $port"
  if ss -tlnp 2>/dev/null | grep -q ":$port "; then
    ok "Listening on 127.0.0.1:$port"
  else
    fail "Nothing listening on port $port"
  fi

  banner "HTTP"
  if http_code=$(curl -s -o /dev/null -w "%{http_code}" "http://127.0.0.1:$port/" --max-time 3 2>/dev/null); then
    if [ "$http_code" = "200" ]; then
      ok "GET / → $http_code"
    else
      warn "GET / → $http_code"
    fi
  else
    fail "Could not connect"
  fi

  banner "Database"
  if [ -f "$HOME/.local/share/media-centarr/media-centarr.db" ]; then
    db_size=$(du -h "$HOME/.local/share/media-centarr/media-centarr.db" 2>/dev/null | cut -f1)
    ok "Exists ($db_size)"
  else
    fail "Database file not found"
  fi

  if systemctl --user is-active --quiet "$service" 2>/dev/null; then
    banner "Supervision"
    diag "status()"

    banner "Recent Console Entries"
    diag "log_recent(20)"

    banner "Services"
    diag "services()"

    banner "Playback"
    diag "playback()"

    banner "Recent Errors (last 5 min)"
    journalctl --user -u "$service" --no-pager --since "5 min ago" -p err 2>/dev/null | tail -20 || info "None"
  fi
}

cmd_logs() {
  local lines="${1:-100}"
  exec journalctl --user -u "$service" --no-pager -n "$lines" -f
}

cmd_errors() {
  local since="${1:-1h}"
  banner "Errors (last $since)"
  journalctl --user -u "$service" --no-pager --since "$since ago" -p err 2>/dev/null || info "None"
}

cmd_mpv_env() {
  banner "mpv launch environment"

  if ! systemctl --user is-active --quiet "$service" 2>/dev/null; then
    fail "Service not running — cannot inspect environment"
    return 1
  fi

  local svc_pid
  svc_pid=$(systemctl --user show -p MainPID --value "$service" 2>/dev/null)
  if [ -z "$svc_pid" ] || [ "$svc_pid" = "0" ]; then
    fail "Could not determine service PID"
    return 1
  fi

  info "Service PID: $svc_pid"

  local svc_env
  svc_env=$(tr '\0' '\n' < "/proc/$svc_pid/environ" 2>/dev/null || true)
  if [ -z "$svc_env" ]; then
    fail "Cannot read /proc/$svc_pid/environ (insufficient permissions?)"
    return 1
  fi

  local missing=()
  for var in WAYLAND_DISPLAY DISPLAY XDG_RUNTIME_DIR XDG_SESSION_TYPE; do
    local val
    val=$(printf "%s\n" "$svc_env" | grep -E "^${var}=" | head -1 | cut -d= -f2- || true)
    if [ -n "$val" ]; then
      ok "$var = $val"
    else
      missing+=("$var")
    fi
  done

  if [ ${#missing[@]} -gt 0 ]; then
    fail "Service is missing display vars: ${missing[*]}"
    info "mpv will fail to create a window (status 1) and \`--no-terminal\`"
    info "silences its error message, so the backend sees only:"
    info "  \"mpv exited (status 1) before playback started\""
    info ""
    info "Fix: restart the service after the graphical session has imported"
    info "its env into systemd-user. Run on the desktop:"
    info "  systemctl --user import-environment WAYLAND_DISPLAY DISPLAY XDG_SESSION_TYPE"
    info "  systemctl --user restart $service"
    info ""
    info "Long-term: make sure your compositor's autostart imports the env"
    info "before starting media-centarr (or add it to the unit's [Service])."
  fi

  banner "Current systemd-user environment"
  for var in WAYLAND_DISPLAY DISPLAY XDG_RUNTIME_DIR XDG_SESSION_TYPE; do
    local val
    val=$(systemctl --user show-environment 2>/dev/null | grep -E "^${var}=" | head -1 | cut -d= -f2- || true)
    if [ -n "$val" ]; then
      info "$var = $val"
    else
      info "$var = (unset)"
    fi
  done
}

cmd_remote() {
  require_release
  require_running
  echo "Connecting to production node... (Ctrl+\\ to disconnect)"
  exec "$bin" remote
}

cmd_log() {
  require_release
  require_running

  local subcmd="${1:-recent}"
  shift 2>/dev/null || true

  case "$subcmd" in
    recent)
      local count="${1:-20}"
      diag "log_recent($count)"
      ;;
    *)
      echo "Log visibility is controlled from the browser console (press backtick)."
      echo ""
      echo "Available log subcommands:"
      echo "  log recent [N]    Print the N most recent buffer entries (default: 20)"
      echo ""
      echo "To filter or search the live buffer, open http://127.0.0.1:$port/console"
      exit 1
      ;;
  esac
}

cmd_help() {
  cat <<EOF
Usage: scripts/troubleshoot [command] [args...]

Commands:
  (none)              Status dashboard — service, port, HTTP, DB, supervision tree, recent console entries
  logs [N]            Tail journal logs (default: last 100, follows)
  errors [PERIOD]     Show error-level logs (default: 1h)
  remote              Open remote IEx shell (Ctrl+\\ to disconnect)
  log recent [N]      Print the N most recent console buffer entries (default: 20)
  mpv-env             Check display env on the service process (Wayland/X11)
                      — catches the silent "mpv exited (status 1)" failure
                      caused by the service starting before the GUI session
  help                This message

Log filtering and live tailing moved to the browser console (press backtick
on any page, or navigate to http://127.0.0.1:$port/console).

Examples:
  scripts/troubleshoot                        # quick health check + recent entries
  scripts/troubleshoot log recent 50          # last 50 buffered log entries
  scripts/troubleshoot logs                   # tail the raw systemd journal
  scripts/troubleshoot errors 24h             # error-level logs from last 24h
EOF
}

# --- Dispatch ---

require_release

cmd="${1:-}"
shift 2>/dev/null || true

case "$cmd" in
  ""|-s|status)   cmd_status ;;
  logs|log-tail)  cmd_logs "$@" ;;
  errors)         cmd_errors "$@" ;;
  remote)         cmd_remote ;;
  log)            cmd_log "$@" ;;
  mpv-env)        cmd_mpv_env ;;
  help|-h|--help) cmd_help ;;
  *)
    echo "Unknown command: $cmd"
    cmd_help
    exit 1
    ;;
esac
