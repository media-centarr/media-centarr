#!/usr/bin/env bash
set -euo pipefail

# Pre-flight check: build a production release locally so you know it
# will compile cleanly and ship the expected artifacts before you tag.
# Usage: scripts/preflight [--clean]
#
# Run this before `/ship <level>`. It produces a release tree at
# _build/prod/rel/media_centarr/ containing bin/media-centarr-install
# and share/systemd/media-centarr.service — the files the in-app
# updater needs end users to receive. If the build fails here, tagging
# would just publish a broken release.
#
# This is NOT a deployment step. Deployment is tagging + pushing;
# local production catches up through Settings > Overview → Update now.
# There is no `scripts/install`.

cd "$(dirname "$0")/.."

clean=false
for arg in "$@"; do
  case "$arg" in
    --clean) clean=true ;;
    *) echo "Unknown flag: $arg"; exit 1 ;;
  esac
done

banner() { echo "==> $1"; }

if [ "$clean" = true ]; then
  banner "Cleaning _build/prod"
  rm -rf _build/prod
fi

banner "Fetching dependencies"
MIX_ENV=prod mix deps.get --only prod

banner "Compiling"
MIX_ENV=prod MIX_OS_DEPS_COMPILE_PARTITION_COUNT=8 mix compile

banner "Deploying assets"
MIX_ENV=prod mix assets.deploy

# Sync defaults/media-centarr.toml into the release overlay so the bundled
# installer can seed it on first install. Source of truth stays in defaults/;
# the overlay copy is gitignored.
banner "Syncing config defaults into release overlay"
mkdir -p rel/overlays/share/defaults
cp defaults/media-centarr.toml rel/overlays/share/defaults/media-centarr.toml

banner "Building release"
MIX_ENV=prod mix release --overwrite

release_path="_build/prod/rel/media_centarr"
banner "Release built at: $(pwd)/$release_path"
"$release_path/bin/media_centarr" version
