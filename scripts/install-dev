#!/usr/bin/env bash
set -euo pipefail

# Install the dev systemd user service for media-centarr backend.
# Usage: scripts/install-dev

cd "$(dirname "$0")/.."

banner() { echo "==> $1"; }

source_dir="$(pwd)"
unit_src="defaults/media-centarr-dev.service"
unit_dst="$HOME/.config/systemd/user/media-centarr-dev.service"
service_name="media-centarr-dev"

# 1. Install patched systemd unit
banner "Installing systemd unit to $unit_dst"
mkdir -p "$(dirname "$unit_dst")"

# Guard against a foreign symlink (e.g. a stow'd dotfile) sitting at the
# destination. The repo is meant to be the sole source of truth for this
# unit so that renaming or moving the repo directory doesn't leave the
# unit pointing at a stale path. Writing through a dotfiles symlink would
# silently edit the dotfile and defeat that guarantee.
if [ -L "$unit_dst" ]; then
  link_target="$(readlink -f "$unit_dst" || true)"
  echo "error: $unit_dst is a symlink to $link_target"
  echo ""
  echo "Remove the unit from the dotfiles repo that's stowing it, then"
  echo "unlink it here and re-run this script:"
  echo ""
  echo "  rm $unit_dst"
  echo "  scripts/install-dev"
  exit 1
fi

sed \
  -e "s|WorkingDirectory=.*|WorkingDirectory=$source_dir|" \
  "$unit_src" > "$unit_dst"

# 2. Reload systemd
banner "Reloading systemd"
systemctl --user daemon-reload

# 3. Restart service if active
if systemctl --user is-active --quiet "$service_name"; then
  banner "Restarting service"
  systemctl --user restart "$service_name"
fi

# 4. Status summary
banner "Install complete"
echo "  Source:  $source_dir"
echo "  Unit:    $unit_dst"
echo ""
systemctl --user status "$service_name" --no-pager 2>/dev/null || echo "  Service is not running. Start with: systemctl --user start $service_name"
