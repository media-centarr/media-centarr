#!/usr/bin/env bash
# Screenshot tour for the showcase instance — navigates to every major
# UI surface in a headed Chromium and saves PNGs into
# docs-site/assets/screenshots/.
#
# Prerequisites:
#   1. Showcase DB created and seeded (all prefixed with the override env var):
#        MEDIA_CENTARR_CONFIG_OVERRIDE=defaults/media-centarr-showcase.toml mix ecto.create
#        MEDIA_CENTARR_CONFIG_OVERRIDE=defaults/media-centarr-showcase.toml mix ecto.migrate
#        MEDIA_CENTARR_CONFIG_OVERRIDE=defaults/media-centarr-showcase.toml mix seed.showcase
#   2. Server running with the showcase override (binds :4003):
#        MEDIA_CENTARR_CONFIG_OVERRIDE=defaults/media-centarr-showcase.toml mix phx.server
#   3. Hyprland running (for the floating-window rule). Not strictly
#      required — Chromium will just open normally on other compositors.
#
# Output: docs-site/assets/screenshots/{library-grid,library-detail-movie,...}.png

set -euo pipefail

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
BASE_URL="${BASE_URL:-http://127.0.0.1:4003}"

# Wait up to 30s for the showcase server to bind — the common workflow
# is "scripts/start-showcase & ; scripts/screenshot-tour" and the BEAM
# takes a few seconds to compile + migrate + listen on first boot.
SERVER_WAIT_SECONDS=30
for _ in $(seq 1 "$SERVER_WAIT_SECONDS"); do
  curl --silent --fail --max-time 1 "$BASE_URL" > /dev/null 2>&1 && break
  sleep 1
done

if ! curl --silent --fail --max-time 3 "$BASE_URL" > /dev/null 2>&1; then
  echo "error: showcase server not reachable at $BASE_URL after ${SERVER_WAIT_SECONDS}s" >&2
  echo "" >&2
  echo "Start it first with:" >&2
  echo "" >&2
  echo "    scripts/start-showcase" >&2
  echo "" >&2
  exit 1
fi

# Hyprland window rules — only applied if hyprctl is available. Float
# the tour's Chromium window so it doesn't get auto-tiled.
#
# The launch config (test/e2e/screenshot-tour.config.js) forces XWayland
# with --ozone-platform=x11 and sets --class=media-centarr. That lands a
# literal WM_CLASS of "media-centarr" on the tour window only, so a
# single exact-match rule is surgical — it cannot touch the user's other
# Chromium windows.
#
# Reload first to wipe any transient rules from an earlier tour run;
# otherwise stale wildcards (e.g. "class:^(Chromium)$" from a different
# session) keep affecting regular browser windows until reboot.
if command -v hyprctl > /dev/null 2>&1; then
  hyprctl reload > /dev/null 2>&1 || true
  for rule in \
    "float, class:^media-centarr$" \
    "size 1400 900, class:^media-centarr$" \
    "center, class:^media-centarr$" \
    "noinitialfocus, class:^media-centarr$"
  do
    hyprctl keyword windowrulev2 "$rule" > /dev/null 2>&1 || true
  done
fi

mkdir -p "$REPO_ROOT/docs-site/assets/screenshots"

# Entity UUIDs for the detail-modal tour stops change every reseed. Look
# them up fresh here so the tour never needs manual editing. If the DB
# is missing (showcase not yet created), the vars stay empty and the
# tour's waitFor selectors time out cleanly — a visible failure rather
# than a silent miss.
SHOWCASE_DB="$REPO_ROOT/priv/showcase/media-centarr.db"
if [ -f "$SHOWCASE_DB" ]; then
  NOSFERATU_ID=$(sqlite3 "$SHOWCASE_DB" "SELECT id FROM library_movies WHERE name = 'Nosferatu' LIMIT 1;" 2>/dev/null || true)
  PIONEER_ONE_ID=$(sqlite3 "$SHOWCASE_DB" "SELECT id FROM library_tv_series WHERE name = 'Pioneer One' LIMIT 1;" 2>/dev/null || true)
  export NOSFERATU_ID PIONEER_ONE_ID
fi

cd "$REPO_ROOT/test/e2e"
BASE_URL="$BASE_URL" bunx playwright test \
  --config=screenshot-tour.config.js \
  --headed \
  "$@"
