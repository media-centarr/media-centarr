# Local MCP server config (machine-specific)
.mcp.json

# Release overlay synthesized at build time from defaults/media-centarr.toml.
# Source of truth lives in defaults/; the overlay copy is regenerated by
# scripts/preflight and the release CI workflow.
/rel/overlays/share/defaults/media-centarr.toml

# Build info written by the release CI workflow (version, built_at, git_sha).
# Absent in dev/test — the app falls back to a "dev build" label.
/priv/build_info.json

# Showcase demo data — populated by `mix seed.showcase` with the shipped
# override TOML. Self-contained inside the repo so `rm -rf priv/showcase/`
# resets the demo cleanly.
/priv/showcase/media/
/priv/showcase/images/
/priv/showcase/*.db
/priv/showcase/*.db-*

# The directory Mix will write compiled artifacts to.
/_build/

# If you run "mix test --cover", coverage assets end up here.
/cover/

# The directory Mix downloads your dependencies sources to.
/deps/

# Where 3rd-party dependencies like ExDoc output generated docs.
/doc/

# Ignore .fetch files in case you like to edit your project deps locally.
/.fetch

# If the VM crashes, it generates a dump, let's ignore it too.
erl_crash.dump

# Also ignore archive artifacts (built via "mix archive.build").
*.ez

# Temporary files, for example, from tests.
/tmp/

# Ignore package tarball (built via "mix hex.build").
media_centarr-*.tar

# Ignore assets that are produced by build tools.
/priv/static/assets/

# Ignore digested assets cache.
/priv/static/cache_manifest.json

# In case you use Node.js/npm, you want to ignore these.
npm-debug.log
/assets/node_modules/

# Local env varibales
/.envrc

# Serena IDE plugin
/.serena/

# Playwright E2E tests
/test/e2e/node_modules/
/test/e2e/test-results/
/test-results/
/playwright-report/

# sqlite stuff
/media_centarr_dev*
/priv/repo/*.db
/priv/repo/*.db-shm
/priv/repo/*.db-wal

# Runtime data (downloaded images, etc.)
/data/
.superpowers/

# Local AI tooling state (machine-specific)
/.claude/settings.json

# Internal project backlog
/todo/
